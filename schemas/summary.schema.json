{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Summary",
  "description": "Public summary for GitHub Pages. Generated by Cowork after each scrape run.",
  "type": "object",
  "required": ["generated_at", "center", "radius_miles", "center_lat", "center_lon", "artist_shows", "venue_shows", "changes"],
  "properties": {
    "generated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Date this summary was generated (YYYY-MM-DD)"
    },
    "center": {
      "type": "string",
      "description": "Center city name"
    },
    "radius_miles": {
      "type": "number"
    },
    "center_lat": {
      "type": "number",
      "description": "Latitude of center city (for map rendering)"
    },
    "center_lon": {
      "type": "number",
      "description": "Longitude of center city (for map rendering)"
    },
    "artist_shows": {
      "type": "object",
      "description": "Same structure as concert_state.json artist_shows",
      "additionalProperties": {
        "type": "array",
        "items": { "$ref": "#/definitions/SummaryShow" }
      }
    },
    "venue_shows": {
      "type": "object",
      "description": "Same structure as concert_state.json venue_shows",
      "additionalProperties": {
        "type": "array",
        "items": { "$ref": "#/definitions/SummaryVenueShow" }
      }
    },
    "changes": {
      "type": "object",
      "description": "Diff from previous run",
      "properties": {
        "artists": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/ArtistChanges" }
        },
        "venues": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/VenueChanges" }
        },
        "total_added": { "type": "number" },
        "total_removed": { "type": "number" },
        "total_sold_out": { "type": "number" }
      }
    }
  },
  "definitions": {
    "SummaryShow": {
      "type": "object",
      "required": ["date", "venue", "city", "status"],
      "properties": {
        "date": { "type": "string" },
        "venue": { "type": "string" },
        "city": { "type": "string" },
        "status": { "enum": ["on_sale", "sold_out"] },
        "distance_miles": { "type": ["number", "null"] },
        "lat": { "type": ["number", "null"] },
        "lon": { "type": ["number", "null"] },
        "is_new": { "type": "boolean", "description": "True if this show was added in the latest run" }
      }
    },
    "SummaryVenueShow": {
      "type": "object",
      "required": ["date", "artist", "tracked"],
      "properties": {
        "date": { "type": "string" },
        "artist": { "type": "string" },
        "tracked": { "type": "boolean" }
      }
    },
    "ArtistChanges": {
      "type": "object",
      "properties": {
        "added": { "type": "array", "items": { "$ref": "#/definitions/SummaryShow" } },
        "removed": { "type": "array", "items": { "$ref": "#/definitions/SummaryShow" } },
        "newly_sold": { "type": "array", "items": { "$ref": "#/definitions/SummaryShow" } }
      }
    },
    "VenueChanges": {
      "type": "object",
      "properties": {
        "added": { "type": "array", "items": { "$ref": "#/definitions/SummaryVenueShow" } },
        "removed": { "type": "array", "items": { "$ref": "#/definitions/SummaryVenueShow" } }
      }
    }
  }
}
