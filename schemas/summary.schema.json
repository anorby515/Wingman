{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Summary",
  "description": "Public summary for GitHub Pages. Generated by Cowork after each scrape run.",
  "type": "object",
  "required": ["generated_at", "center", "center_lat", "center_lon", "artist_shows", "venue_shows", "changes"],
  "properties": {
    "generated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Date this summary was generated (YYYY-MM-DD)"
    },
    "center": {
      "type": "string",
      "description": "Map home city name"
    },
    "radius_miles": {
      "type": ["number", "null"],
      "description": "Deprecated — kept for backward compat"
    },
    "center_lat": {
      "type": "number",
      "description": "Latitude of center city (for map rendering)"
    },
    "center_lon": {
      "type": "number",
      "description": "Longitude of center city (for map rendering)"
    },
    "artist_shows": {
      "type": "object",
      "description": "Map of artist name to all North America shows",
      "additionalProperties": {
        "type": "array",
        "items": { "$ref": "#/definitions/SummaryShow" }
      }
    },
    "venue_shows": {
      "type": "object",
      "description": "Map of venue name to events at that venue",
      "additionalProperties": {
        "type": "array",
        "items": { "$ref": "#/definitions/SummaryVenueShow" }
      }
    },
    "changes": {
      "type": "object",
      "description": "Diff from previous run",
      "properties": {
        "artists": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/ArtistChanges" }
        },
        "venues": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/VenueChanges" }
        },
        "total_added": { "type": "number" },
        "total_removed": { "type": "number" },
        "total_sold_out": { "type": "number" }
      }
    },
    "coming_soon": {
      "type": "array",
      "description": "Shows not yet on public sale, sourced from Ticketmaster. Written by Cowork during weekly scrape.",
      "items": { "$ref": "#/definitions/ComingSoonShow" }
    },
    "coming_soon_fetched": {
      "type": ["string", "null"],
      "description": "ISO 8601 datetime when coming_soon was last fetched from Ticketmaster"
    }
  },
  "definitions": {
    "SummaryShow": {
      "type": "object",
      "required": ["date", "venue", "city", "status"],
      "properties": {
        "date": { "type": "string" },
        "venue": { "type": "string" },
        "city": { "type": "string" },
        "status": { "enum": ["on_sale", "sold_out"] },
        "lat": { "type": ["number", "null"] },
        "lon": { "type": ["number", "null"] },
        "is_new": { "type": "boolean", "description": "True if this show was added in the latest run" }
      }
    },
    "SummaryVenueShow": {
      "type": "object",
      "required": ["date", "artist", "tracked"],
      "properties": {
        "date": { "type": "string" },
        "artist": { "type": "string" },
        "tracked": { "type": "boolean" }
      }
    },
    "ArtistChanges": {
      "type": "object",
      "properties": {
        "added": { "type": "array", "items": { "$ref": "#/definitions/SummaryShow" } },
        "removed": { "type": "array", "items": { "$ref": "#/definitions/SummaryShow" } },
        "newly_sold": { "type": "array", "items": { "$ref": "#/definitions/SummaryShow" } }
      }
    },
    "VenueChanges": {
      "type": "object",
      "properties": {
        "added": { "type": "array", "items": { "$ref": "#/definitions/SummaryVenueShow" } },
        "removed": { "type": "array", "items": { "$ref": "#/definitions/SummaryVenueShow" } }
      }
    },
    "ComingSoonPresale": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "description": "Presale name, e.g. 'Fan Club Presale'" },
        "start_datetime": { "type": ["string", "null"], "description": "ISO 8601 presale start" },
        "end_datetime": { "type": ["string", "null"], "description": "ISO 8601 presale end" }
      }
    },
    "ComingSoonShow": {
      "type": "object",
      "required": ["artist", "date", "venue", "city", "ticketmaster_url"],
      "properties": {
        "artist": { "type": "string" },
        "genre": { "type": "string" },
        "date": { "type": "string", "description": "Display date, e.g. 'Aug 15, 2026'" },
        "venue": { "type": "string" },
        "city": { "type": "string" },
        "onsale_datetime": { "type": ["string", "null"], "description": "ISO 8601 public on-sale start" },
        "onsale_tbd": { "type": "boolean" },
        "presales": {
          "type": "array",
          "items": { "$ref": "#/definitions/ComingSoonPresale" }
        },
        "ticketmaster_url": { "type": "string" },
        "lat": { "type": ["number", "null"] },
        "lon": { "type": ["number", "null"] }
      }
    }
  }
}
