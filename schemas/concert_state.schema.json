{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ConcertState",
  "description": "Current state of scraped concert data. Written by Cowork, read by frontend and diff logic.",
  "type": "object",
  "required": ["last_run", "center", "radius_miles", "artist_shows", "venue_shows"],
  "properties": {
    "last_run": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Date of last scrape run (YYYY-MM-DD)"
    },
    "center": {
      "type": "string",
      "description": "Center city for radius calculation, e.g. 'Des Moines, IA'"
    },
    "radius_miles": {
      "type": "number",
      "minimum": 0,
      "description": "Search radius in miles from center city"
    },
    "artist_shows": {
      "type": "object",
      "description": "Map of artist name to array of shows within radius",
      "additionalProperties": {
        "type": "array",
        "items": { "$ref": "#/definitions/Show" }
      }
    },
    "venue_shows": {
      "type": "object",
      "description": "Map of venue name to array of events at that venue",
      "additionalProperties": {
        "type": "array",
        "items": { "$ref": "#/definitions/VenueShow" }
      }
    }
  },
  "definitions": {
    "Show": {
      "type": "object",
      "required": ["date", "venue", "city", "status"],
      "properties": {
        "date": {
          "type": "string",
          "description": "Display date, e.g. 'Mar 15, 2026'"
        },
        "venue": {
          "type": "string",
          "description": "Venue name"
        },
        "city": {
          "type": "string",
          "description": "City and state, e.g. 'Kansas City, MO'"
        },
        "status": {
          "type": "string",
          "enum": ["on_sale", "sold_out"]
        },
        "distance_miles": {
          "type": ["number", "null"],
          "description": "Haversine distance from center city in miles"
        },
        "lat": {
          "type": ["number", "null"],
          "description": "Venue latitude"
        },
        "lon": {
          "type": ["number", "null"],
          "description": "Venue longitude"
        }
      }
    },
    "VenueShow": {
      "type": "object",
      "required": ["date", "artist", "tracked"],
      "properties": {
        "date": {
          "type": "string",
          "description": "Display date"
        },
        "artist": {
          "type": "string",
          "description": "Artist or event name"
        },
        "tracked": {
          "type": "boolean",
          "description": "True if artist matches a tracked artist in config"
        }
      }
    }
  }
}
